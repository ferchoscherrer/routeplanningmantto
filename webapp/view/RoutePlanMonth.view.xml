<mvc:View 
    controllerName="routeplanningmantto.controller.RoutePlanMonth"
    xmlns:mvc="sap.ui.core.mvc" 
    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mc="sap.suite.ui.microchart">
    
    <Page title="Programación Mensual de Servicios" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <VBox width="100%" height="100%" renderType="Bare">
                <HBox class="sapUiSmallMargin" wrap="Wrap" justifyContent="Start" style="flex-shrink: 0;">
                    <VBox class="metricCardSmall">
                        <Text text="Equipos" class="metricLabel" />
                        <Title text="{db>/TotalEquipos}" titleStyle="H2" class="metricValue" />
                    </VBox>
                    <VBox class="metricCardSmall">
                        <Text text="Distancia Total" class="metricLabel" />
                        <Title text="{db>/TotalKm} km" titleStyle="H2" class="metricValue" />
                    </VBox>
                    <VBox class="metricCardSmall">
                        <Text text="Mecánicos" class="metricLabel" />
                        <Title text="{db>/TotalMecanicos}" titleStyle="H2" class="metricValue" />
                    </VBox>
                </HBox>

                <HBox width="100%" renderType="Bare" style="flex-grow: 1;">
                    <VBox width="60%" class="sapUiSmallMarginBegin sapUiSmallMarginEnd" style="height: 100%;">
                        <Toolbar style="Clear">
                            <Title text="Rutas por programar" level="H4" />

                            <ComboBox 
        id="comboFechaFiltro"
        width="110px"
        placeholder="Seleccionar Mes/Año"
        selectionChange=".onFechaChange">
        <items>
            </items>
    </ComboBox>

                            <ToolbarSpacer />
                            <Button 
                                id="btnSelectAll"
                                icon="sap-icon://multiselect-all" 
                                tooltip="Seleccionar Todo"
                                press=".onSelectAll" />
                            
                            <Button 
                                id="btnGenerarOrdenes"
                                text="Generar Órdenes" 
                                icon="sap-icon://Post" 
                                type="Emphasized" 
                                press=".onGenerarOrdenes"
                                enabled="false" /> 
                            <SearchField width="30%" search=".onSearchService" placeholder="Buscar..." />
                        </Toolbar>
                        
                        <ScrollContainer height="calc(100vh - 250px)" vertical="true" focusable="true">
                            <List id="routeList" 
                                mode="None"
                                items="{
                                    path: 'db>/ServicesRouteSet/results', 
                                    sorter: [
                                        {path: 'GroupKey', group: true, descending: false}, 
                                        {path: 'CargaNum', descending: false}
                                    ], 
                                    groupHeaderFactory: '.getGroupHeader'
                                }">
                                <CustomListItem>
                                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMargin">
                                        <HBox alignItems="Center">
                                            <Avatar displaySize="XS" initials="{db>CargaNum}" class="sapUiTinyMarginEnd" backgroundColor="Accent6" />
                                            <VBox>
                                                <Text text="{db>Nombre}" fontWeight="Bold" />
                                                <Text text="Eq: {db>Tipo} - {db>Equipo}" style="font-size: 0.85rem;" />
                                                <Text text="Serie: {db>Serie}" fontWeight="Bold" color="#1C4D7D" />
                                                <HBox visible="{= !!${db>Orden} }">
                                                    <ObjectStatus text="Orden: {db>Orden}" state="Success" class="sapUiTinyMarginEnd" />
                                                    <ObjectStatus text="{db>Mensaje}" state="{= ${db>Orden} ? 'Success' : 'Error'}" 
                                                        visible="{= !!${db>Mensaje} }" />
                                                </HBox>
                                                <Text text="Niveles: {db>Niveles}" fontWeight="Bold" color="#1C4D7D" />
                                                <Text text="Contrato: {db>Contrato} | Pos: {db>Posicion}" fontWeight="Bold" color="#1C4D7D" />
                                                <Text text="Mecánico: {db>Mecanico}" fontWeight="Bold" color="#1C4D7D" />
                                                <Text text="Ultima: {db>UltimaOrden}" fontWeight="Bold" color="#1C4D7D" />
                                               <VBox class="sapUiTinyMarginTop">
    <Text text="PROGRAMA DE MANTENIMIENTO ANUAL" fontWeight="Bold" color="#1C4D7D" />
    
    <Text 
        text="{
            path: 'db>Paquetes',
            formatter: '.formatPaquetes'
        }" 
        style="font-size: 0.85rem;" 
        color="#666666" />
</VBox>
                                            </VBox>
                                        </HBox>

                                        <HBox alignItems="Center">
                                            <VBox alignItems="End" class="sapUiSmallMarginEnd">
                                                <Text text="{db>FechaFull}" fontWeight="Bold" />
                                                <ObjectStatus text="{db>RankingTexto}" state="Indication05" />
                                            </VBox>
                                            <CheckBox selected="{db>Selected}" select=".onSelectionChange" visible="{= !${db>Orden} }" />
                                        </HBox>
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </ScrollContainer>
                    </VBox>

                    <VBox width="40%" style="border-left: 1px solid #e5e5e5;" class="sapUiSmallMargin">
                        <Title text="Carga de Trabajo por Técnico" level="H4" class="sapUiSmallMarginBottom" />
                        <List id="mechanicsList" items="{path: 'db>/MecanicosStats', sorter: {path: 'PorcentajeCarga', descending: true}}">
                            <CustomListItem>
                                <VBox class="sapUiSmallMargin">
                                    <HBox justifyContent="SpaceBetween">
                                        <Text text="{db>Nombre}" fontWeight="Bold" />
                                        <Text text="{db>KmTotales} km totales" style="font-size: 0.85rem; color: #666;" />
                                    </HBox>
                                    <ProgressIndicator 
                                        percentValue="{db>PorcentajeCarga}" 
                                        displayValue="{db>PorcentajeCarga}%" 
                                        state="{path: 'db>PorcentajeCarga', formatter: '.formatProgressState'}" 
                                        height="1.2rem"
                                        class="sapUiTinyMarginTop" />
                                </VBox>
                            </CustomListItem>
                        </List>
                    </VBox>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>