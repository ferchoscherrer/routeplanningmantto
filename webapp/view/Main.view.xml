<mvc:View 
    controllerName="routeplanningmantto.controller.Main"
    xmlns:mvc="sap.ui.core.mvc" 
    displayBlock="true"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f">
    
    <tnt:ToolPage id="toolPage">
        <tnt:header>
            <tnt:ToolHeader>
                <Button icon="sap-icon://menu2" type="Transparent" press=".onSideNavButtonPress" />
                <Title text="AntsRoute Clone" class="sapUiSmallMarginEnd" />
                
                <ToolbarSeparator />
                <Button text="Probar OData" press=".testODataConnection" type="Emphasized" />
                <Button text="Programar diario" icon="sap-icon://calendar" type="Transparent" press=".onProgramar" />
                <Button text="Programar Mensual" icon="sap-icon://calendar" type="Transparent" press=".onProgramarMensual" />
                <Button text="Planeación Estratégica" icon="sap-icon://calendar" type="Transparent" press=".onStrategicPlanningNav" />
                <Button text="Organizar" icon="sap-icon://Chart-Tree-Map" type="Transparent" press=".onOrganizar" />
                <Button text="Seguir" icon="sap-icon://locate-me" type="Emphasized" press=".onSeguir" />
                <Button text="Analizar" icon="sap-icon://business-objects-experience" type="Transparent" press=".onAnalizar" />

                <ToolbarSpacer />
                
                <Button icon="sap-icon://search" type="Transparent" />
                <Button icon="sap-icon://bell" type="Transparent" />
                <Avatar src="" displaySize="XS" class="sapUiTinyMarginEnd" />
            </tnt:ToolHeader>
        </tnt:header>

        <tnt:sideContent>
    <tnt:SideNavigation>
        <tnt:item>
            <tnt:NavigationList>
                <tnt:NavigationListItem text="Mapa" icon="sap-icon://map" />
                <tnt:NavigationListItem text="Intervenciones" icon="sap-icon://list" />
                <tnt:NavigationListItem text="Expediente" icon="sap-icon://customer-and-contacts" select=".onOpenExpediente" />
                
                <tnt:NavigationListItem text="Supervisores" icon="sap-icon://employee-lookup" select=".onShowSupervisores" />
                <tnt:NavigationListItem text="Mecánicos" icon="sap-icon://wrench" select=".onShowMecanicos" />
                <tnt:NavigationListItem text="Equipos" icon="sap-icon://machine" select=".onShowEquipos" />
            </tnt:NavigationList>
        </tnt:item>
    </tnt:SideNavigation>
</tnt:sideContent>

        <tnt:mainContents>
            <VBox fitContainer="true" class="sapUiSmallMargin">
                <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                    <GenericTile header="Rutas no Iniciadas">
                        <tileContent><TileContent><NumericContent value="0" icon="sap-icon://notes" /></TileContent></tileContent>
                    </GenericTile>
                    <GenericTile header="En Proceso">
                        <tileContent><TileContent><NumericContent value="2" valueColor="Critical" icon="sap-icon://synchronize" /></TileContent></tileContent>
                    </GenericTile>
                    <GenericTile header="Finalizadas">
                        <tileContent><TileContent><NumericContent value="0" valueColor="Good" icon="sap-icon://accept" /></TileContent></tileContent>
                    </GenericTile>
                    <GenericTile header="No Asignados">
                        <tileContent><TileContent><NumericContent value="1" valueColor="Error" icon="sap-icon://employee" /></TileContent></tileContent>
                    </GenericTile>
                </HBox>

                <HBox height="100%" renderType="Bare">
                    <VBox width="65%" height="100%" class="sapUiTinyMarginEnd">
                        <core:HTML id="mapContainer" 
                            content='&lt;div id="googleMap" style="height: 100%; width: 100%; border-radius: 12px; border: 1px solid #dcdcdc; box-shadow: 0 2px 5px rgba(0,0,0,0.1);"&gt;&lt;/div&gt;' />
                    </VBox>

                    <VBox width="35%" height="100%" style="background: white; border-radius: 12px; border: 1px solid #dcdcdc; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                        <Toolbar style="Clear">
                            <Title text="Intervenciones" level="H4" class="sapUiSmallMarginBegin" />
                            <ToolbarSpacer />
                            <Button icon="sap-icon://sort" type="Transparent" />
                        </Toolbar>
                        <List items="{localModel>/intervenciones}" noDataText="Sin actividad">
                            <CustomListItem type="Active" press=".onIntervencionPress">
                                <HBox class="sapUiSmallMargin" justifyContent="SpaceBetween" alignItems="Center">
                                    <VBox>
                                        <Text text="{localModel>nombre}" fontWeight="Bold" />
                                        <Text text="{localModel>unidad}" color="DimGray" />
                                    </VBox>
                                    <ObjectStatus text="{localModel>estado}" state="{localModel>state}" inverted="true" />
                                </HBox>
                            </CustomListItem>
                        </List>
                    </VBox>
                </HBox>
            </VBox>
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>