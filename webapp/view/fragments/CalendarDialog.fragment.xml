<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified">
    <Dialog title="Calendario de Citas Globales" contentWidth="95%" contentHeight="90%" resizable="true" draggable="true">
        <content>
            <SinglePlanningCalendar
                id="idGlobalCalendar"
                startDate="{db>/StartDate}"
                appointments="{path: 'db>/CitasGlobales', templateShareable: false}">
                <views>
                    <SinglePlanningCalendarMonthView key="Month" title="Vista Mensual" />
                </views>
                <appointments>
                    <unified:CalendarAppointment
                        startDate="{db>startDate}"
                        endDate="{db>endDate}"
                        title="{db>title}"
                        text="{db>text}" 
                        type="{db>type}"
                        icon="{db>icon}" />
                </appointments>
            </SinglePlanningCalendar>
        </content>
        <beginButton>
            <Button text="Cerrar" type="Emphasized" press=".onCloseCalendarDialog" />
        </beginButton>
    </Dialog>
</core:FragmentDefinition>