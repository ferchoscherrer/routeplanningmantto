{
  "_version": "1.83.0",
  "sap.app": {
    "id": "routeplanningmantto",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "dataSources": {
        "mainService": {
            "uri": "/sap/opu/odata/sap/ZCS_GETDATA_PLANNING_ROUTE_SRV/",
            "type": "OData",
            "settings": {
                "odataVersion": "2.0",
                "localUri": "localService/metadata.xml"
            }
        },
        "ZSD_CATALOGOS_SRV": {
        "uri": "sap/opu/odata/sap/ZSD_CATALOGOS_SRV?sap-language=es",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/metadata.xml",
          "odataVersion": "2.0"
        }
      },
       "ZCS_GET_EMPLOYE_SRV": {
        "uri": "sap/opu/odata/sap/ZCS_GET_EMPLOYE_SRV?sap-language=es",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    },
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "7335a205-e568-41e7-a409-10675b98fcf4"
    },
    "crossNavigation": {
      "inbounds": {
        "routeplanningmantto-Display": {
          "semanticObject": "routeplanningmantto",
          "action": "Display",
          "title": "{{routeplanningmantto-Display.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.unified": {},
      "sap.ui.layout": {},
      "sap.tnt": {},
        "sap.ui.vbm": {
        "lazy": false
      },
      "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "db": {
            "dataSource": "mainService",
            "settings": {
                "defaultBindingMode": "TwoWay"
        }},
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "routeplanningmantto.i18n.i18n"
        }
      },
      "ZSD_CATALOGOS_SRV": {
        "dataSource": "ZSD_CATALOGOS_SRV",
        "preload": true,
        "settings": {
          "useBatch": true
        }
      },
      "ZCS_GET_EMPLOYE_SRV": {
        "dataSource": "ZCS_GET_EMPLOYE_SRV",
        "preload": true,
        "settings": {
          "useBatch": true
        }}
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "routeplanningmantto.view",
        "async": true,
        "viewPath": "routeplanningmantto.view"
      },
      "routes": [
        {
          "name": "RouteMain",
          "pattern": ":?query:",
          "target": [
            "TargetMain"
          ]
        },
        {
          "name": "RoutePlanMonth",
          "pattern": "RoutePlanMonth",
          "target": [
            "TargetRoutePlanMonth"
          ]
        },
        {
    "name": "RouteStrategicPlanning",
    "pattern": "StrategicPlanning",
    "target": ["TargetStrategicPlanning"]
  }
      ],
      "targets": {
        "TargetMain": {
          "id": "Main",
          "name": "Main",
          "viewLevel": 1
        },
        "TargetRoutePlanMonth": {
          "id": "RoutePlanMonth",
          "name": "RoutePlanMonth",
          "viewLevel": 2
        },
        "TargetStrategicPlanning": {
    "id": "StrategicPlanning",
    "name": "StrategicPlanning",
    "viewLevel": 3
  }
      }
    },
    "rootView": {
      "viewName": "routeplanningmantto.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "routeplanningmantto"
  }
}
